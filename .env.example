# 应用配置
PY_ADMIN_PROJECT_NAME=Py-Admin
PY_ADMIN_PROJECT_VERSION=0.1.0
PY_ADMIN_ENVIRONMENT=development
PY_ADMIN_DEBUG=true
PY_ADMIN_HOST=0.0.0.0
PY_ADMIN_PORT=8000
PY_ADMIN_RELOAD=true

# 日志
PY_ADMIN_LOG_LEVEL=DEBUG
PY_ADMIN_ACCESS_LOG_ENABLED=true

# 数据库 (MySQL)
PY_ADMIN_DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/py_admin?charset=utf8mb4
PY_ADMIN_SQL_ECHO=true
PY_ADMIN_DB_POOL_SIZE=10
PY_ADMIN_DB_MAX_OVERFLOW=20
PY_ADMIN_DB_POOL_RECYCLE=3600

# CORS
PY_ADMIN_CORS_ORIGINS=["*"]
PY_ADMIN_CORS_ALLOW_CREDENTIALS=false

# API 文档（production 环境会强制关闭）
PY_ADMIN_DOCS_ENABLED=true
PY_ADMIN_DOCS_URL=/docs
PY_ADMIN_REDOC_URL=/redoc
PY_ADMIN_OPENAPI_URL=/openapi.json
PY_ADMIN_SWAGGER_JS_URL=https://cdn.bootcdn.net/ajax/libs/swagger-ui/5.17.14/swagger-ui-bundle.js
PY_ADMIN_SWAGGER_CSS_URL=https://cdn.bootcdn.net/ajax/libs/swagger-ui/5.17.14/swagger-ui.css
